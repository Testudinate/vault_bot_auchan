# ╔══════════════════════════════════════════════════════════════╗
# ║  .env — Конфигурация проекта                                 ║
# ║  ВАЖНО: не добавляйте .env в git! (см. .gitignore)           ║
# ║  Это ШАБЛОН — заполните своими значениями и сохраните как .env║
# ╚══════════════════════════════════════════════════════════════╝

# ── Telegram ──────────────────────────────────
TELEGRAM_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
ALLOWED_USER_ID=0
MY_EMAIL=your_login@example.com

# ── Claude API (Anthropic) ────────────────────
ANTHROPIC_KEY=YOUR_ANTHROPIC_API_KEY

# ── Grok API (xAI) — STT и chat ──────────────
GROK_KEY=YOUR_GROK_API_KEY

# ── Auchan корпоративный LLM ─────────────────
AUCHAN_LLM_URL=YOUR_AUCHAN_LLM_URL
AUCHAN_API_KEY=YOUR_AUCHAN_GRAVITEE_API_KEY
AUCHAN_BEARER=YOUR_AUCHAN_BEARER_TOKEN

# ── Groq API (Llama) ──────────────────────────
GROQ_KEY=YOUR_GROQ_API_KEY

# ── Яндекс Почта (IMAP) ───────────────────────
YANDEX_LOGIN=your_login@yandex.ru
YANDEX_PASSWORD=your_app_password

# ── Яндекс Диск (OAuth) ───────────────────────
YANDEX_DISK_TOKEN=YOUR_YANDEX_OAUTH_TOKEN

# ── Яндекс Мессенджер (Bot API) ───────────────
YANDEX_BOT_TOKEN=YOUR_YANDEX_BOT_TOKEN

# ── Confluence ────────────────────────────────
CONFLUENCE_URL=YOUR_CONFLUENCE_URL
CONFLUENCE_USER=your_login
CONFLUENCE_PASSWORD=your_password
CONFLUENCE_SPACE=YOUR_SPACE_KEY

# ── JIRA ──────────────────────────────────────
JIRA_URL=YOUR_JIRA_URL
JIRA_USER=your_login
JIRA_PASSWORD=your_password
JIRA_PROJECT=YOUR_PROJECT_KEY

# ── JupyterHub ────────────────────────────────
JH_TOKEN=YOUR_JUPYTER_TOKEN
JH_URL=YOUR_JUPYTERHUB_URL
MY_KERNEL_ID=YOUR_KERNEL_ID

# ── Пути ──────────────────────────────────────
VAULT_PATH=./ObsidianVault
PLAUD_TXT_FOLDER=./plaud_transcripts
YANDEX_MESSENGER_EXPORT=./messenger_export
YANDEX_DISK_FOLDER=./yandex_disk_files
LOCAL_AI_FOLDER=./

# ── Настройки бота ────────────────────────────
DIGEST_WEEKDAY=0
DIGEST_HOUR=7
SYNC_EVERY_HOURS=1
DISK_ROOT_FOLDER=/
MAX_FILE_SIZE_MB=10
GROK_LANGUAGE=ru
GROK_CHAT_MODEL=grok-3-turbo
GROQ_MODEL=llama-3.1-8b-instant
DEFAULT_MODEL=haiku
